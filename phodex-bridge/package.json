{
  "name": "domaeng",
  "version": "1.5.1",
  "description": "Local bridge between Codex and the Domaeng web app. Run `domaeng up` to start.",
  "main": "src/index.js",
  "bin": {
    "domaeng": "./bin/remodex.js",
    "domaeng-jsonl-diagnose": "./bin/remodex-jsonl-diagnose.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node ./bin/remodex.js up",
    "test": "node --test ./test/*.test.js",
    "postinstall": "node ./src/bootstrap-codex-cli.js",
    "prepack": "node ./scripts/prepare-private-defaults.js",
    "postpack": "node ./scripts/cleanup-private-defaults.js"
  },
  "keywords": [
    "domaeng",
    "codex",
    "bridge",
    "cli"
  ],
  "author": "Domaeng contributors",
  "license": "Apache-2.0",
  "type": "commonjs",
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0"
  }
}
